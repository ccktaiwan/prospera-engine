name: Architecture Integrity Check

on:
pull_request:
branches:
- main

jobs:
architecture-check:
runs-on: ubuntu-latest

```
steps:
  - name: Checkout repository
    uses: actions/checkout@v4

  - name: Verify architecture documents
    run: |
      echo "Checking required architecture files..."

      test -f 01_ARCHITECTURE/SYSTEM_OVERVIEW.md
      test -f 01_ARCHITECTURE/SYSTEM_CONTEXT.md
      test -f 01_ARCHITECTURE/RUNTIME_MODEL.md
      test -f 01_ARCHITECTURE/COMPONENT_MODEL.md

      echo "Checking required specification files..."

      test -f 02_SPECIFICATIONS/EVENT_SCHEMA.md
      test -f 02_SPECIFICATIONS/STATE_MODEL.md

      echo "Checking governance files..."

      test -f 03_GOVERNANCE/ARCHITECTURE_CONSTRAINTS.md

      echo "Architecture integrity check passed."
```
